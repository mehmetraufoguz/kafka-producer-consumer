{
  "name": "kafka-producer-consumer",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "pnpm --filter shared build",
    "dev:all": "concurrently \"pnpm --filter api dev\" \"pnpm --filter consumer dev\" \"pnpm --filter producer dev\" \"pnpm --filter sentiment dev\" \"pnpm --filter dashboard dev\"",
    "build:all": "pnpm --filter shared build && pnpm --filter api build && pnpm --filter consumer build && pnpm --filter producer build && pnpm --filter sentiment build && pnpm --filter dashboard build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "docker:logs": "docker compose logs -f",
    "docs:dev": "vocs dev",
    "docs:build": "vocs build",
    "docs:preview": "vocs preview",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "lint": "eslint \"**/*.{ts,tsx,js,jsx}\""
  },
  "dependencies": {
    "vocs": "1.0.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}